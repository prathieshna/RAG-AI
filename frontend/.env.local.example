# Copy this file to .env.local and adjust if needed.
#
# This variable is read by next.config.ts at server start.
# It sets the destination for the /api/* rewrite proxy.
#
# Default (Flask running on the same machine):
FLASK_API_URL=http://localhost:5001

# Flask running on another machine on your LAN:
# FLASK_API_URL=http://192.168.1.50:5000
